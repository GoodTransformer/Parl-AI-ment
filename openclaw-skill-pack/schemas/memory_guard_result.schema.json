{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://parl-ai-ment.local/schemas/memory_guard_result.schema.json",
  "title": "Parl-AI-ment Memory Guard Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "status",
    "memory_mode",
    "memory_plugin",
    "memory_flush",
    "workspace_access",
    "dedicated_runtime",
    "notes"
  ],
  "properties": {
    "status": {
      "type": "string",
      "enum": [
        "pass",
        "warn",
        "fail"
      ]
    },
    "memory_mode": {
      "$ref": "./shared_enums.json#/$defs/memoryMode"
    },
    "memory_plugin": {
      "type": "string",
      "enum": [
        "disabled",
        "enabled",
        "unknown"
      ]
    },
    "memory_flush": {
      "type": "string",
      "enum": [
        "disabled",
        "enabled",
        "unknown"
      ]
    },
    "workspace_access": {
      "type": "string",
      "enum": [
        "none",
        "ro",
        "rw",
        "unknown"
      ]
    },
    "dedicated_runtime": {
      "type": "boolean"
    },
    "notes": {
      "type": "array",
      "maxItems": 20,
      "items": {
        "type": "string",
        "minLength": 3,
        "maxLength": 300
      }
    }
  }
}
